Http ~ "lib.ua"
~ "../uwu-utils/lib.ua" ~ Strings

# --- Header unit tests ---

Http~Headers!(
  Default
  Add "A" "Foo"
  Add "A" "Bar"
  Add "B" "Baz"
)
ЋЩвН§вЙН {{"A" "A" "B"} {"Foo" "Bar" "Baz"}}

Http~Headers!(
  Default
  Set "A" "Foo"
  Set "A" "Bar"
)
ЋЩвН§вЙН {{"A"} {"Bar"}}

Http~Headers!(
  Default
  Add "A" "Foo"
  Add "B" "Bar"

  Default
  Add "B" "Baz"
  Add "C" "Qux"

  MergeOverride
)
ЋЩвН§вЙН {{"A" "B" "C"} {"Foo" "Baz" "Qux"}}

# --- Request parsing tests ---

StringAsStream вЖЪ (
  вН£(¬∞$"_\n\n_"|вКЩ"")
  /$"_\r\n_" ¬∞/$"_\n_"
  $"_\r\n\r\n_"
  &fo "test" вНЬ(&fc "test"|ЋЬ&w)
)

$ GET /hello/world?foo=bar HTTP/1.1
$ Host: example.com
StringAsStream
Http~ParseRequestFromStream
Http~Request!вКГ(
  ЋЩвН§вЙН "GET" Method
| ЋЩвН§вЙН "example.com" Host
| ЋЩвН§вЙН "/hello/world" Path
| ЋЩвН§вЙН "foo=bar" Query
| ЋЩвН§вЙН {{"Host"} {"example.com"}} Headers
| ЋЩвН§вЙН [] Body
)

$ POST /foo/bar HTTP/1.1
$ Host: example.com
$ Content-Length: 13
$ 
$ Hello, world!
Http~ParseRequestFromStream StringAsStream
Http~Request!вКГ(
  ЋЩвН§вЙН "POST" Method
| ЋЩвН§вЙН "example.com" Host
| ЋЩвН§вЙН "/foo/bar" Path
| ЋЩвН§вЙН "" Query
| ЋЩвН§вЙН {{"Host" "Content-Length"} {"example.com" "13"}} Headers
| ЋЩвН§вЙН utfвВИ"Hello, world!" Body
)

# --- Response parsing tests ---

$ HTTP/1.1 204 No Content
$ 
Http~ParseResponseFromStream StringAsStream
Http~Response!вКГ(
  ЋЩвН§вЙН 204 StatusCode
| ЋЩвН§вЙН {{} {}} Headers
| ЋЩвН§вЙН [] Body
)

$ HTTP/1.1 200 OK
$ Content-Length: 5
$ 
$ Hello
Http~ParseResponseFromStream StringAsStream
Http~Response!вКГ(
  ЋЩвН§вЙН 200 StatusCode
| ЋЩвН§вЙН {{"Content-Length"} {"5"}} Headers
| ЋЩвН§вЙН utfвВИ"Hello" Body
)

# --- Request building tests ---

RequestToString вЖР Http!(
  Request~ToRawRequest
  ¬∞utfвВИ RawRequest~ToBytes
  Strings~Replace "\r\n" "\n"
)

Http~BuildRequest!(
  Method "GET"
  Url "http://example.com/hello/world?foo=bar"
)
RequestToString
$ GET /hello/world?foo=bar HTTP/1.1
$ Host: example.com
$ 
$ 
ЋЩвН§вЙН

Http~BuildRequest!(
  Method "GET"
  Host "example.com"
  Path "/hello/world"
  Query "foo=bar"
  Body "Hello, world!"
  AddHeader "Custom-Header" "CustomValue"
  AddHeader "Content-Length" "1111"
)
RequestToString
$ GET /hello/world?foo=bar HTTP/1.1
$ Custom-Header: CustomValue
$ Content-Length: 13
$ Host: example.com
$ 
$ Hello, world!
ЋЩвН§вЙН

# --- Response building tests ---

ResponseToString вЖР Http!(
  Response~ToRawResponse
  ¬∞utfвВИ RawResponse~ToBytes
  Strings~Replace "\r\n" "\n"
)

Http~BuildResponse!(
  StatusCode 200
  Body "Hello, world!"
  AddHeader "Content-Type" "text/plain"
)
ResponseToString
$ HTTP/1.1 200
$ Content-Type: text/plain
$ Content-Length: 13
$ 
$ Hello, world!
ЋЩвН§вЙН

Http~BuildResponse!(
  StatusCode 204
)
ResponseToString
$ HTTP/1.1 204
$ 
$ 
ЋЩвН§вЙН
